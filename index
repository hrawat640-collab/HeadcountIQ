  document.getElementById('runway-statement').innerHTML =
    `Under the <strong>On plan</strong> scenario, with ${bal.finalHires} new hires adding ${fc(bal.totalCost)}/month to your costs, your estimated runway is <strong>${rws[1]} months</strong>. ` +
    (rws[1] >= S.horizon+6 ? 'This is healthy — you have significant buffer beyond your planning horizon.' :
     rws[1] >= S.horizon ? 'This covers your planning horizon with some buffer.' :
     'This is below your planning horizon. Consider phasing hires or securing additional funding before hiring at this pace.');

  document.getElementById('runway-tbody').innerHTML = [
    {label:'Cautious', p:cons, rwy:rws[0], idx:0},
    {label:'On plan', p:bal, rwy:rws[1], idx:1},
    {label:'Stretch', p:agg, rwy:rws[2], idx:2},
