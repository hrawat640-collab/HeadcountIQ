function updatePvaSummary() {
  if(!plan)return;
  const{depts,hiresM}=plan.bal.mp;
  let totalActual=0,totalPlanned=0;
  depts.forEach(d=>{hiresM[d].forEach((_,mi)=>{totalPlanned+=hiresM[d][mi]||0;totalActual+=(pvActuals[d]?.[mi]?.hires)||0;});});
  const diff=totalActual-totalPlanned;
  document.getElementById('pva-actual').textContent=totalActual;
  const vEl=document.getElementById('pva-var-hires');
  vEl.textContent=(diff>=0?'+':'')+diff+' vs plan';
  vEl.style.color=diff===0?'var(--i600)':diff>0?'var(--t600)':'var(--r600)';

  // Ops variance
  const plannedOps=S.ops.tools+S.ops.rent+S.ops.ctors+S.ops.other;
  let totalActualOps=0;
  plan.bal.mp.horizon&&Array.from({length:plan.bal.mp.horizon},(_,mi)=>{totalActualOps+=(pvActuals['__ops']?.[mi]?.cost||0)*1000/CURR.fx;});
  const opsDiff=totalActualOps-(plannedOps*plan.bal.mp.horizon);
  const opEl=document.getElementById('pva-var-ops');
  opEl.textContent=opsDiff===0?'On track':fc(Math.abs(opsDiff))+(opsDiff>0?' over':' under');
