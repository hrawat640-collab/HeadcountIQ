function updateEstTotal() {
  const cat = document.getElementById('est-category').value;
  const rows = estRows[cat] || [];
  const avgSal = plan ? Object.values(plan.bal.deptSal).reduce((a,b)=>a+b,0)/Math.max(Object.values(plan.bal.deptSal).length,1)/12 : 80000;
  const empCount = S.empCount || 48;
  const hires = plan?.bal?.finalHires || 10;

  let total = 0, resultNote = '';

  if (cat === 'hiring') {
    rows.forEach(r => {
      if (r.type === 'pct') total += (r.val/100) * avgSal * 12;
      else total += r.val;
    });
    const pct = avgSal * 12 > 0 ? (total / (avgSal * 12) * 100).toFixed(1) : 0;
    resultNote = `${pct}% of avg annual salary · ${fc(total)} per hire · ${fc(total*hires)} total for ${hires} hires`;
    document.getElementById('est-total-display').innerHTML = `<div class="est-total-bar"><div><div class="est-total-label">Per hire</div><div class="est-result-note">${resultNote}</div></div><div class="est-total-val">${fc(total)}</div></div>`;
  } else if (cat === 'onboarding') {
    rows.forEach(r => {
      if (r.type === 'months') total += r.val * avgSal;
      else total += r.val;
    });
    const mult = avgSal > 0 ? (total / avgSal).toFixed(2) : 0;
    resultNote = `${mult}× monthly salary · ${fc(total)} per hire · ${fc(total*hires)} for ${hires} hires`;
    document.getElementById('est-total-display').innerHTML = `<div class="est-total-bar"><div><div class="est-total-label">Per hire · ${mult}× monthly salary</div><div class="est-result-note">${resultNote}</div></div><div class="est-total-val">${fc(total)}</div></div>`;
  } else if (cat === 'benefits') {
    const basicSal = avgSal * 0.4; // basic = 40% of annual salary
    rows.forEach(r => {
      if (r.type === 'pct_basic') total += r.val / 100 * basicSal * empCount;
      else total += r.val * empCount;
    });
    const pct = avgSal * empCount > 0 ? (total / (avgSal * empCount) * 100).toFixed(1) : 0;
    resultNote = `${pct}% of monthly payroll · ${fc(total/empCount)}/employee/month`;
    document.getElementById('est-total-display').innerHTML = `<div class="est-total-bar"><div><div class="est-total-label">Monthly total · ${pct}% of payroll</div><div class="est-result-note">${resultNote}</div></div><div class="est-total-val">${fc(total)}/mo</div></div>`;
  } else {
    rows.forEach(r => total += r.val);
    document.getElementById('est-total-display').innerHTML = `<div class="est-total-bar"><div><div class="est-total-label">Monthly total</div><div class="est-result-note">Annual: ${fc(total*12)}</div></div><div class="est-total-val">${fc(total)}/mo</div></div>`;
  }

  // Store for "use in plan"
  window._estResult = { cat, total, rows };
}

function useEstimatorResult() {
  if (!window._estResult) return;
  const { cat, total, rows } = window._estResult;
  const avgSal = plan ? Object.values(plan.bal.deptSal).reduce((a,b)=>a+b,0)/Math.max(Object.values(plan.bal.deptSal).length,1)/12 : 80000;

  if (cat === 'hiring') {
    const pct = avgSal * 12 > 0 ? Math.round(total/(avgSal*12)*100) : 18;
    document.getElementById('rate-hiring').value = pct;
    document.getElementById('e-rate-hiring').value = pct;
