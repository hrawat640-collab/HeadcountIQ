    else{row=costM[dept].map(c=>Math.round(c*CURR.fx/1000));cls='cost-n';}
    const rowTot=view==='cumulative'?row[row.length-1]:view==='headcount'?row[row.length-1]:row.reduce((a,b)=>a+b,0);
    html+=`<tr><td class="dept-cell">${dept}${subLabel}</td>
      ${row.map(v=>{const c=v===0?(view==='hires'?'zero':''):cls;return`<td class="${c}">${v===0&&view==='hires'?'—':(view==='cost'&&v>0?CURR.sym+v+'K':v)}</td>`;}).join('')}
      <td class="${cls}">${view==='cost'?CURR.sym+rowTot+'K':rowTot}</td>
