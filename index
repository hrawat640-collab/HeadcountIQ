function selectPace(btn, mult, label) {
  if(!plan) return;
  document.querySelectorAll('.pace-chip').forEach(c=>c.classList.remove('active')); btn.classList.add('active');
  const chosen = computePlan(mult);
  const maxRev = S.currRev + chosen.finalHires*(S.currRev/Math.max(S.empCount,1));
  document.getElementById('m-hires').textContent = chosen.finalHires;
  document.getElementById('m-hires-s').textContent = chosen.growthHires+' growth + '+chosen.attritionHires+' backfill';
  const mra=document.getElementById('m-rev-achiev'); if(mra) mra.textContent=fc(maxRev);
  document.getElementById('m-burn').textContent = fc(chosen.payroll)+'/mo';
