}

function updateEstRowWithPeriod(cat, idx, val, period) {
  const monthly = period === 'annual' ? (parseFloat(val)||0)/12 : (parseFloat(val)||0);
  if (estRows[cat]) estRows[cat][idx].val = monthly;
  updateEstTotal();
}

function setEstPeriod(cat, idx, period, btn) {
  estPeriods[cat+idx] = period;
  btn.closest('.est-period-toggle').querySelectorAll('.est-period-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
