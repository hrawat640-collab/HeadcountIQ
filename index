function buildKpiSection(bal,coType){
  const rpe=S.currRev/Math.max(S.empCount,1);
  const hcG=S.empCount>0?(bal.finalHires/S.empCount*100).toFixed(1):0;
  const bm=S.tgtRev>S.currRev?(bal.totalCost*12/(S.tgtRev-S.currRev)).toFixed(2):'N/A';
  const pp=S.currRev>0?(bal.payroll*12/S.currRev*100).toFixed(1):0;
  const computed=[{lbl:'Revenue per employee',val:fc(rpe),sub:'Current baseline'},{lbl:'Headcount growth',val:hcG+'%',sub:bal.growthHires+' growth + '+bal.attritionHires+' backfill'},{lbl:'Burn multiple',val:bm+'x',sub:'New cost / net new revenue'},{lbl:'Payroll as % of revenue',val:pp+'%',sub:'Post-hire, annualised'}];
  const manuals={product:[{lbl:'Annual recurring revenue growth',key:'arr-growth',ph:'e.g. 150%'},{lbl:'Gross margin',key:'gm',ph:'e.g. 72%'},{lbl:'Net revenue retention',key:'nrr',ph:'e.g. 115%'},{lbl:'Customer acquisition cost',key:'cac',ph:fc(100000)},{lbl:'Runway (months)',key:'runway',ph:'e.g. 18'}],services:[{lbl:'Active clients',key:'clients',ph:'e.g. 42'},{lbl:'Revenue per client',key:'rpc',ph:fc(5000000)},{lbl:'Utilisation rate',key:'util',ph:'e.g. 78%'},{lbl:'Bench headcount',key:'bench',ph:'e.g. 12%'},{lbl:'Net Promoter Score',key:'nps',ph:'e.g. 42'}],marketplace:[{lbl:'Gross merchandise value',key:'gmv',ph:fc(10000000)},{lbl:'Take rate',key:'tr',ph:'e.g. 15%'},{lbl:'Active buyers monthly',key:'buyers',ph:'e.g. 45,000'},{lbl:'Repeat purchase rate',key:'repeat',ph:'e.g. 65%'},{lbl:'NPS',key:'nps2',ph:'e.g. 38'}]};
  const ms=manuals[coType]||manuals.product;
  const ch=computed.map(k=>'<div class="bkpi"><div class="bkpi-lbl">'+k.lbl+'</div><div class="bkpi-val" contenteditable="true">'+k.val+'</div><div class="bkpi-sub">'+k.sub+'</div></div>').join('');
  const mh=ms.map(k=>'<div class="bkpi manual" id="kpi-'+k.key+'"><button class="bkpi-del board-print-hide" onclick="removeKpi(\'kpi-'+k.key+'\')">×</button><div class="bkpi-lbl" contenteditable="true">'+k.lbl+'</div><input class="bkpi-input" placeholder="'+k.ph+'"/><div class="bkpi-sub">Enter your figure</div></div>').join('');
  const bn='<div class="burn-explainer board-print-hide"><strong>Burn multiple ('+bm+'x):</strong> For every rupee of new revenue targeted, you are spending '+bm+' rupees. Below 1.0 is capital-efficient. Above 2.0 is common in early stages. Above 3.0 warrants a review of hiring pace.</div>';
  return '<div class="kpi-grid">'+ch+'</div><div class="kpi-grid">'+mh+'</div><button class="add-kpi-btn board-print-hide" onclick="addCustomKpi()">+ Add KPI</button>'+bn;
}
