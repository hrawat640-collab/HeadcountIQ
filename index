  let html=`<table class="hc-table"><thead><tr><th class="dept-h">Dept / Sub-dept</th>${months.map(m=>`<th class="month-h">${m}</th>`).join('')}<th style="background:#0a4f47;text-align:right;">Total</th></tr></thead><tbody>`;
