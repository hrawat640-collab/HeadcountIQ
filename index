function fc(inr) {
  const v=inr*CURR.fx;
  if(CURR.code==='INR'){if(v>=10000000)return'₹'+(v/10000000).toFixed(1)+'Cr';if(v>=100000)return'₹'+(v/100000).toFixed(1)+'L';if(v>=1000)return'₹'+(v/1000).toFixed(0)+'K';return'₹'+Math.round(v);}
