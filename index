function buildCashFlowChart(bal) {
  const hasFunds = currentFunds > 0;
  document.getElementById('cash-flow-section').style.display = hasFunds ? '' : 'none';
  document.getElementById('add-funds-prompt').style.display = hasFunds ? 'none' : '';
  if (!hasFunds) return;

  const months = getMonthLabels(S.horizon);
  const burn = monthlyBurnRate || (S.ops.tools+S.ops.rent+S.ops.ctors+S.ops.other) || currentFunds*0.05;
  const {depts,costM} = bal.mp;

  // Month-by-month cash position
  let cash = currentFunds;
  const cashData = [];
  let fundraiseMonth = null;
  const monthlyRevGrowth = S.currRev/12; // assume flat revenue (conservative)

  months.forEach((m, mi) => {
    const hireCost = depts.reduce((s,d)=>s+(costM[d]?.[mi]||0),0);
    const totalBurn = burn + hireCost;
    const revenue = monthlyRevGrowth;
    cash = cash - totalBurn + revenue;
    cashData.push(Math.round(cash*CURR.fx/100000)/10); // in L/M
    if (cash < burn*3 && !fundraiseMonth) fundraiseMonth = mi;
  });

  // Signal
  const finalCash = cashData[cashData.length-1];
  const signalEl = document.getElementById('fundraise-signal');
  const signalText = document.getElementById('fundraise-signal-text');
  if (fundraiseMonth !== null) {
    signalEl.className = 'fundraise-signal warn';
    signalText.innerHTML = `<strong>Fundraise by ${months[Math.max(0,fundraiseMonth-2)]}:</strong> At this hiring pace, your cash drops below 3 months of burn around ${months[fundraiseMonth]}. Start fundraising conversations at least 2 months earlier to maintain operations.`;
  } else if (finalCash > 0) {
    signalEl.className = 'fundraise-signal ok';
    signalText.innerHTML = `<strong>Cash positive through plan:</strong> Your funds plus projected revenue cover this hiring plan for the full ${S.horizon} months with ${CURR.sym}${Math.abs(finalCash).toFixed(1)}${CURR.code==='INR'?'L':'M'} remaining.`;
  } else {
    signalEl.className = 'fundraise-signal danger';
    signalText.innerHTML = `<strong>Cash runs out before plan completes:</strong> Consider reducing hiring pace (Cautious scenario) or securing funding before executing this plan.`;
  }

  // Chart
  const ctx = document.getElementById('cashFlowChart');
  if (!ctx) return;
  if (charts.cashFlow) charts.cashFlow.destroy();
  const zeroLine = Array(months.length).fill(0);
  charts.cashFlow = new Chart(ctx, {
    type:'line',
    data:{labels:months, datasets:[
      {label:`Cash position (${CURR.sym}${CURR.code==='INR'?'L':'M'})`,data:cashData,borderColor:'#2D4A8A',backgroundColor:'rgba(45,74,138,.08)',fill:true,tension:0.3,pointRadius:3,pointBackgroundColor:'#2D4A8A'},
      {label:'Zero cash',data:zeroLine,borderColor:'#C0373C',borderDash:[4,3],borderWidth:1.5,pointRadius:0,fill:false},
    ]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:true,labels:{boxWidth:10,font:{family:'Figtree',size:11},color:'#7A7466'}}},scales:{x:{grid:{display:false},ticks:{color:'#9B9589',font:{family:'Figtree',size:10}},border:{display:false}},y:{grid:{color:'rgba(0,0,0,0.04)'},ticks:{color:'#9B9589',font:{family:'Figtree',size:11},callback:v=>CURR.sym+v+(CURR.code==='INR'?'L':'M')},border:{display:false}}}}
  });
}

function buildLevelPieCharts(bal) {
  if (!bal) return;
  const mix = BM.lvMix[S.stage] || BM.lvMix['Series A'];
  const colors = ['#4A6CB3','#2D4A8A','#0E6B5E','#138B7A','#6B3FA0'];
  const depts = Object.keys(bal.deptHires).filter(d=>bal.deptHires[d]>0);

  // 1. Planned hire mix by level
  const plannedCounts = LKS.map(lvl =>
    depts.reduce((s,d)=>s+(bal.deptLevels[d]?.[lvl]||0),0)
  ).filter((v,i)=>v>0||true);
  buildPie('piePlanned', LKS, plannedCounts, colors);

  // 2. Post-hire cumulative mix (estimated current + planned)
  const curCounts = LKS.map(lvl => Math.round(S.empCount*(mix[lvl]||0)/100));
  const cumulCounts = LKS.map((lvl,i) => curCounts[i] + plannedCounts[i]);
  buildPie('pieCumul', LKS, cumulCounts, colors);
}

