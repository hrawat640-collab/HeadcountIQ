function computePlan(scMult) {
  const eff=BM.eff[S.stage]?.m||1.25, rpe=S.currRev/S.empCount;
  const maxRev=S.currRev*eff, revGap=Math.max(0,S.tgtRev-maxRev);
  let raw=revGap/rpe; if(raw>S.empCount*0.3)raw*=0.8;

  // Attrition replacements (prorated to horizon)
  const attritionHires=Math.round(S.empCount*(S.attrition/100)*(S.horizon/12));
  const growthHires=Math.max(0,Math.round(raw*scMult));
  const finalHires=growthHires+attritionHires;

  const sliders=document.querySelectorAll('#sliders-wrap .sl-track');
  const rawDist={};sliders.forEach(s=>{rawDist[s.dataset.dept]=parseInt(s.value)});
  const dSum=Object.values(rawDist).reduce((a,b)=>a+b,0)||100;
  const dist={};Object.entries(rawDist).forEach(([d,v])=>{dist[d]=v/dSum});

  const deptHires={};Object.entries(dist).forEach(([d,pct])=>{deptHires[d]=Math.max(0,Math.round(finalHires*pct))});
  const hSum=Object.values(deptHires).reduce((a,b)=>a+b,0);
  if(hSum!==finalHires&&finalHires>0){const top=Object.entries(deptHires).sort((a,b)=>b[1]-a[1])[0]?.[0];if(top)deptHires[top]+=(finalHires-hSum);}

  const payMap={};
  Array.from(document.getElementById('dtbl-body').rows).forEach(r=>{
    const d=r.cells[0].querySelector('input').value.trim();
    const hc=parseInt(r.cells[2].querySelector('input').value)||0;
    const sal=parseFloat(r.cells[3].querySelector('input').value)||0;
    if(d&&hc>0&&sal>0)payMap[d]=sal/hc*12;
  });
  const subMap={};
  Array.from(document.getElementById('dtbl-body').rows).forEach(r=>{const d=r.cells[0].querySelector('input').value.trim();const sub=r.cells[1].querySelector('input').value.trim();if(d&&sub)subMap[d]=sub;});

  const deptSal={};Object.keys(deptHires).forEach(d=>{deptSal[d]=payMap[d]||(BM.sal[d]||BM.sal.Operations).median*100000;});

  const rates=getRates();
  const payroll=Object.entries(deptHires).reduce((s,[d,h])=>s+h*deptSal[d]/12,0);
  const hiringCost=Object.entries(deptHires).reduce((s,[d,h])=>s+h*deptSal[d]*rates.hiring/12,0);
  const onbCost=Object.entries(deptHires).reduce((s,[d,h])=>s+h*(deptSal[d]/12)*rates.onboard/12,0);
  const benCost=payroll*rates.benefits;
  const opsTotal=S.ops.tools+S.ops.rent+S.ops.ctors+S.ops.other;
  const totalCost=payroll+hiringCost+onbCost+benCost+opsTotal;

  const h=S.horizon;
  const phases=[{months:Math.max(1,Math.round(h*0.3)),pct:0.30},{months:Math.max(1,Math.round(h*0.4)),pct:0.50},{months:Math.max(1,h-Math.round(h*0.3)-Math.round(h*0.4)),pct:0.20}];
  const mix=BM.lvMix[S.stage]||BM.lvMix['Series A'];
  const deptLevels={};
  Object.entries(deptHires).filter(([,h])=>h>0).forEach(([dept,total])=>{
    const lvls={};let rem=total;
    LKS.forEach((lvl,i)=>{if(i===LKS.length-1)lvls[lvl]=Math.max(0,rem);else{const n=Math.round(total*mix[lvl]/100);lvls[lvl]=n;rem-=n;}});
    const ls=Object.values(lvls).reduce((a,b)=>a+b,0);if(ls!==total){const mx=Object.entries(lvls).sort((a,b)=>b[1]-a[1])[0]?.[0];if(mx)lvls[mx]+=(total-ls);}
    deptLevels[dept]=lvls;
  });
  const mp=buildMP(deptHires,phases,h,deptSal,subMap);
  return{finalHires,growthHires,attritionHires,rpe,revGap,maxRev,deptHires,deptSal,deptLevels,payroll,hiringCost,onbCost,benCost,opsTotal,totalCost,phases,mp,rates,subMap};
}

function buildMP(deptHires,phases,horizon,salAnnual,subMap) {
  const depts=Object.keys(deptHires).filter(d=>deptHires[d]>0);
  const ph=[0,phases[0].months,phases[0].months+phases[1].months,horizon];
  const hiresM={},costM={};
  depts.forEach(dept=>{
    hiresM[dept]=Array.from({length:horizon},(_,mi)=>{for(let p=0;p<3;p++){if(mi>=ph[p]&&mi<ph[p+1])return Math.round(deptHires[dept]*phases[p].pct/Math.max(phases[p].months,1));}return 0;});
    const ms=(salAnnual[dept]||160000)/12;
    costM[dept]=hiresM[dept].map(h=>h*ms);
  });
  return{depts,hiresM,costM,horizon,subMap};
}

function computeHealth(bal) {
  const bench=BM.ratio[S.industry]||BM.ratio.Default;
  const futHC={};
  Object.entries(bench).forEach(([d,arr])=>{futHC[d]=Math.round(S.empCount*(arr[1]||0)/100)});
  Object.entries(bal.deptHires).forEach(([d,h])=>{futHC[d]=(futHC[d]||0)+h});
  const total=S.empCount+bal.finalHires;
  const eng=futHC['Engineering']||0,qa=futHC['QA']||0;
  const engR=total>0?eng/total*100:0,qaR=eng>0?qa/eng*100:0;
  let status='healthy';
  if(engR<15||qaR<8)status='critical';else if(engR<25||qaR<15)status='at-risk';
  const warns=[];
  if(S.motion==='Sales-led'&&(futHC['Sales']||0)<3)warns.push('Sales team understaffed for Sales-led motion');
  const prod=futHC['Product']||0;if(prod>eng*0.4&&eng>0)warns.push('Product-to-Engineering ratio may slow execution');
  return{futHC,bench,total,engR,qaR,status,warns};
}

function buildInsights(bal,health) {
  const ins=[];
  if(bal.revGap===0)ins.push({t:'ok',i:'✓',title:'Current team can hit target',desc:'Efficiency multiplier covers your goal. Hiring accelerates it.'});
  else ins.push({t:'info',i:'→',title:'Revenue gap: '+fc(bal.revGap),desc:`Gap to bridge at current productivity. Revenue per employee: ${fc(bal.rpe)}`});
  if(bal.attritionHires>0)ins.push({t:'info',i:'→',title:`Attrition adds ${bal.attritionHires} replacement hires`,desc:`${S.attrition}% annual attrition on ${S.empCount} employees over ${S.horizon} months. Included in total.`});
  if(health.status==='critical')ins.push({t:'danger',i:'!',title:'Org health: Critical',desc:'Engineering critically low. Urgently reprioritise technical hiring.'});
  else if(health.status==='at-risk')ins.push({t:'warn',i:'⚠',title:'Org health: At risk',desc:'Engineering or QA below benchmark. Consider rebalancing.'});
  else ins.push({t:'ok',i:'✓',title:'Org health: Healthy',desc:`Engineering (${health.engR.toFixed(1)}%) and QA ratios within range.`});
  if(bal.finalHires>S.empCount*0.5)ins.push({t:'warn',i:'⚠',title:'High growth rate (>50%)',desc:'Growing >50% in one cycle demands strong onboarding investment.'});
  if(bal.opsTotal>0)ins.push({t:'info',i:'→',title:'Ops overhead: '+fc(bal.opsTotal)+'/mo',desc:'Included in Total Growth Cost. Edit in Step 4.'});
  health.warns.forEach(w=>ins.push({t:'warn',i:'⚠',title:'Staffing alert',desc:w}));
  if(bal.totalCost>S.currRev/12*0.25)ins.push({t:'warn',i:'⚠',title:'High burn exposure',desc:'New cost >25% of current monthly revenue. Validate runway.'});
  return ins.slice(0,6);
}

function computeConf() {
  const hasDept=document.getElementById('dtbl-body').rows.length>0;
  const hasSal=hasDept&&Array.from(document.getElementById('dtbl-body').rows).some(r=>parseFloat(r.cells[3].querySelector('input').value)>0);
  const hasAttrition=(S.attrition||0)>0;
  const rates=getRates();const customRates=rates.hiring!==0.18||rates.onboard!==1.25||rates.benefits!==0.13;
  let score=60;if(hasDept)score+=16;if(hasSal)score+=6;if(hasDept&&hasSal)score+=10;if(hasAttrition)score+=5;
  return{score:Math.min(score,92),hasDept,hasSal,hasAttrition,customRates};
}

