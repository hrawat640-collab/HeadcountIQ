function buildStartMonthGrid() {
  const grid = document.getElementById('start-month-grid');
  if (!grid) return;
  const now = new Date();
  const months = [];
  for (let i = 0; i <= 11; i++) {
    const d = new Date(now.getFullYear(), now.getMonth() + i, 1);
    months.push({ label: d.toLocaleDateString('en-GB',{month:'short',year:'2-digit'}), idx: i });
  }
  grid.innerHTML = months.map((m,i) => `
    <div class="month-chip ${i===1?'sel':''}" data-idx="${m.idx}" onclick="selectStartMonth(this,${m.idx})">${m.label}${i===0?' (now)':i===1?' (next)':''}</div>
  `).join('');
  planStartMonth = 1; // default: next month
}

function getMonthLabels(horizon) {
  const now = new Date();
  const startOffset = planStartMonth || 1;
  const labels = [];
  for (let i = 0; i < horizon; i++) {
    const d = new Date(now.getFullYear(), now.getMonth() + startOffset + i, 1);
    labels.push(d.toLocaleDateString('en-GB',{month:'short',year:'2-digit'}));
  }
  return labels;
}

