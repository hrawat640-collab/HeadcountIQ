function buildAllCharts() {
  if (!plan) return;
  const { bal, cons, agg } = plan;
  // Only build charts for canvases that exist in the DOM
  if (document.getElementById('deptChart')) buildDeptChart(bal);
  if (document.getElementById('salChart')) buildSalChart(bal);
  if (document.getElementById('scChart')) buildScChart(cons, bal, agg);
  if (isPro()) {
    if (document.getElementById('costRampChart')) buildRampChart(bal);
    const runways = renderRunway(cons, bal, agg);
    buildProCharts(bal, runways);
    if (document.getElementById('pvaChart')) buildPvaChart(bal.mp);
    if (document.getElementById('trackChart') && currentMode==='track') buildTrackChart(bal.mp);
    setTimeout(() => {
      if (document.getElementById('piePlanned')) buildLevelPieCharts(bal);
    }, 100);
    buildDeptMsDropdown(bal);
  }
}

