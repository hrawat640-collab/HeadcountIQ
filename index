async function loadPlan(id) {
  try {
    const {data} = await sb.from('plans').select('user_plan,active_plan').eq('id',id).single();
    if (data?.user_plan?.roles) {
      userPlanRoles = data.user_plan.roles;
      userCustomCols = data.user_plan.customCols || [];
      renderBudgetTable();
    }
    if (data?.active_plan === 'user' && userPlanRoles.length) {
