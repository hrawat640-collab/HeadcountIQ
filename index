.modal-ftr{background:var(--s50);border-top:1px solid var(--s200);padding:14px 32px;display:flex;align-items:center;gap:12px;border-radius:0 0 var(--rx) var(--rx)}

/* LOADING */
.load-wrap{min-height:calc(100vh - 60px);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px}
