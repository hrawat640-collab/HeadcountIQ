</header>

<!-- ══════ AUTH ══════ -->
<section id="section-auth" class="sec active">
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="auth-logo">
        <div class="auth-lmark">HQ</div>
        <div><div style="font-size:16px;font-weight:700;letter-spacing:-.02em;">Headcount IQ</div><div style="font-size:11px;color:var(--i400);">Workforce Planning</div></div>
      </div>
      <h2 class="auth-title">Plan your team's growth with confidence.</h2>
      <p class="auth-sub">Workforce planning + tracking for growing companies. Build your hiring plan, track actuals, and present to your board.</p>
      <div class="auth-tabs">
        <button class="auth-tab active" id="tab-si" onclick="swAuthTab('si')">Sign in</button>
