  const cumHiresM={};
  depts.forEach(d=>{let c=0;cumHiresM[d]=hiresM[d].map(h=>{c+=h;return c;});});
  // total headcount = starting + cumulative hires
  const startHC={};
  const bench=BM.ratio[S.industry]||BM.ratio.Default;
