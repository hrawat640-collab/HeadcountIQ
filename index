      <div id="auth-ok" class="auth-msg auth-ok"></div>
      <div id="auth-si">
        <div class="fg"><label class="flabel">Email</label><input type="email" class="finput" id="si-email" placeholder="you@company.com" onkeydown="if(event.key==='Enter')doSignIn()"/></div>
        <div class="fg"><label class="flabel">Password</label><input type="password" class="finput" id="si-pass" placeholder="Your password" onkeydown="if(event.key==='Enter')doSignIn()"/></div>
        <button class="btn btn-ink btn-full" onclick="doSignIn()" style="padding:13px;font-size:14px;margin-bottom:10px;">Sign in →</button>
        <button class="btn btn-ghost btn-full" onclick="doForgotPw()" style="font-size:12px;color:var(--i400);">Forgot password?</button>
      </div>
