    document.getElementById('ops-rent').value = Math.round(total);
    document.getElementById('e-ops-rent').value = Math.round(total);
    calcOps(); showToast(`Rent set to ${fc(total)}/mo`);
  } else if (cat === 'contractors') {
    document.getElementById('ops-ctors').value = Math.round(total);
