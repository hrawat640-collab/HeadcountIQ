          </div>
          <div id="fund-signal"></div>
        </div>

        <div class="wnav"><button class="btn btn-ghost" onclick="goStep(1)">← Back</button><button class="btn btn-teal" onclick="goStep(3)">Continue →</button></div>
      </div>

      <!-- STEP 3 -->
      <div class="wstep" id="step-3">
