function applyUserPlan(){if(!userPlanRoles.length){showToast('Add at least one role first');return;}setPlanState('user');if(currentPlanId&&currentUser){sb.from('plans').update({user_plan:{roles:userPlanRoles,customCols:userCustomCols},active_plan:'user'}).eq('id',currentPlanId).then(()=>{});}showToast('Your plan is now active');}
function addBudgetRole(){userPlanRoles.push({title:'New role',department:'Engineering',level:'Mid',count:1,salary:0,custom:{}});renderBudgetTable();}
function addBudgetColumn(){const name=prompt('Column name:');if(!name)return;userCustomCols.push(name);renderBudgetTable();}
function toggleCompare(){const p=document.getElementById('compare-panel-wrap');if(!p)return;if(p.style.display!=='none'){p.style.display='none';return;}if(!plan||!userPlanRoles.length){showToast('Add roles in Budget It first');return;}const hqD=plan.bal.deptHires,uD={},uS={};userPlanRoles.forEach(r=>{uD[r.department]=(uD[r.department]||0)+(r.count||0);if(!uS[r.department])uS[r.department]=[];if(r.salary)uS[r.department].push(r.salary);});const allD=[...new Set([...Object.keys(hqD),...Object.keys(uD)])];let tH=0,tU=0;document.getElementById('compare-tbody').innerHTML=allD.map(d=>{const hq=hqD[d]||0,u=uD[d]||0,df=u-hq;tH+=hq;tU+=u;const hs=(BM.sal[d]||BM.sal.Operations).median;const ua=uS[d]||[];const us=ua.length?ua.reduce((a,b)=>a+b,0)/ua.length/100000:hs;return'<tr><td>'+d+'</td><td>'+hq+'</td><td>'+u+'</td><td class="'+(df>0?'delta-positive':df<0?'delta-negative':'delta-zero')+'">'+(df===0?'Same':(df>0?'+':'')+df)+'</td><td>₹'+hs+'L/yr</td><td>₹'+us.toFixed(1)+'L/yr</td></tr>';}).join('')+'<tr class="total-row"><td>Total</td><td>'+tH+'</td><td>'+tU+'</td><td class="'+(tU-tH>0?'delta-positive':tU-tH<0?'delta-negative':'delta-zero')+'">'+(tU===tH?'Same':(tU-tH>0?'+':'')+(tU-tH))+'</td><td colspan="2"></td></tr>';p.style.display='';}
function updateBudgetRole(idx,field,val){if(userPlanRoles[idx]){userPlanRoles[idx][field]=val;if((field==='department'||field==='level')&&!userPlanRoles[idx].salary)userPlanRoles[idx].salary=getDefaultSalary(userPlanRoles[idx].department||'Engineering',userPlanRoles[idx].level||'Mid');updateBudgetSummary();}}
function deleteBudgetRole(idx){userPlanRoles.splice(idx,1);renderBudgetTable();}
function removeCustomCol(name){userCustomCols=userCustomCols.filter(c=>c!==name);userPlanRoles.forEach(r=>{if(r.custom)delete r.custom[name];});renderBudgetTable();}
function updateBudgetCustomByDeptLvl(dept,lvl,col,val){const r=userPlanRoles.find(r=>r.department===dept&&r.level===lvl);if(r){if(!r.custom)r.custom={};r.custom[col]=val;}}
function importBudgetCsv(){const input=document.createElement('input');input.type='file';input.accept='.csv';input.onchange=e=>{const reader=new FileReader();reader.onload=ev=>{const lines=ev.target.result.split('\n').filter(l=>l.trim()&&!l.toLowerCase().startsWith('role'));lines.forEach(line=>{const[title,dept,lvl,count,salary]=line.split(',').map(x=>x.trim().replace(/^"|"$/g,''));if(title)userPlanRoles.push({title,department:dept||'Engineering',level:lvl||'Mid',count:+count||1,salary:+salary||0,custom:{}});});renderBudgetTable();showToast('Imported '+lines.length+' roles');};reader.readAsText(e.target.files[0]);};input.click();}
