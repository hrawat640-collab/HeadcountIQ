  const grand=view==='cumulative'||view==='headcount'?totals[totals.length-1]:totals.reduce((a,b)=>a+b,0);
  html+=`<tr class="tot-row"><td class="dept-cell">TOTAL${view==='headcount'?' HEADCOUNT':''}</td>${totals.map(v=>`<td>${view==='cost'&&v?CURR.sym+v+'K':v||'—'}</td>`).join('')}<td>${view==='cost'?CURR.sym+grand+'K':grand}</td></tr></tbody></table>`;
  document.getElementById('mplan-scroll').innerHTML=html;

  // Update title
  const viewLabels={'hires':'New hires per month','cumulative':'Cumulative hires','headcount':'Total headcount (starting + hires)','cost':'Monthly payroll cost'};
  document.getElementById('monthly-title').textContent=viewLabels[view]+' — real month view';
