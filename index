.faq-tab-btn{padding:8px 14px;border-radius:var(--rr) var(--rr) 0 0;font-size:12px;font-weight:600;cursor:pointer;border:none;font-family:var(--ss);color:var(--i500);background:transparent;transition:all .15s}
.faq-tab-btn:hover{color:var(--i800)}.faq-tab-btn.active{background:white;color:var(--i900);box-shadow:0 -2px 0 var(--t400) inset}

