    document.getElementById('rate-onboard').value = mult;
    document.getElementById('e-rate-onboard').value = mult;
    showToast(`Onboarding set to ${mult}× monthly salary`);
  } else if (cat === 'benefits') {
    const empCount = S.empCount || 48;
