function renderEstimator() {
  const cat = document.getElementById('est-category').value;
  const defaults = EST_DEFAULTS[cat] || [];
  if (!estRows[cat]) estRows[cat] = defaults.map(d => ({...d, period:'monthly'}));
  const rows = estRows[cat];
  const avgSal = plan ? Object.values(plan.bal.deptSal).reduce((a,b)=>a+b,0) / Math.max(Object.values(plan.bal.deptSal).length,1) / 12 : 80000;
  const empCount = S.empCount || 48;

  let html = '';

  if (cat === 'hiring') {
    html += `<div class="est-section"><div class="est-section-title">Per-hire costs</div>`;
    rows.forEach((row, i) => {
      const isPct = row.type === 'pct';
      const dispVal = isPct ? (row.val || 18) : row.val;
      html += `<div class="est-row">
        <div class="est-row-label">${row.label}<br><span style="font-size:10px;color:var(--i400);">${row.note}</span></div>
        <input class="est-row-input" type="number" value="${dispVal}" step="${isPct?1:100}" onchange="updateEstRow('${cat}',${i},this.value)" style="width:90px;"/>
        <button class="est-del" onclick="delEstRow('${cat}',${i})">✕</button>
      </div>`;
    });
    html += `<button class="est-add-row" onclick="addEstRow('${cat}')">+ Add row</button></div>`;
  } else if (cat === 'benefits') {
    html += `<div class="est-section"><div class="est-section-title">Per employee / month</div>
      <div style="font-size:11px;color:var(--i500);margin-bottom:10px;">Using avg monthly salary: ${fc(avgSal)} · Headcount: ${empCount}</div>`;
    rows.forEach((row, i) => {
      html += `<div class="est-row">
        <div class="est-row-label">${row.label}<br><span style="font-size:10px;color:var(--i400);">${row.note}</span></div>
        <input class="est-row-input" type="number" value="${row.val}" step="0.1" onchange="updateEstRow('${cat}',${i},this.value)" style="width:90px;"/>
        <button class="est-del" onclick="delEstRow('${cat}',${i})">✕</button>
      </div>`;
    });
    html += `<button class="est-add-row" onclick="addEstRow('${cat}')">+ Add row</button></div>`;
  } else {
    // tools, rent, contractors, other, onboarding
    html += `<div class="est-section"><div class="est-section-title">Cost items</div>`;
    rows.forEach((row, i) => {
      const period = estPeriods[cat+i] || 'monthly';
      html += `<div class="est-row">
        <div class="est-row-label">${row.label}<br><span style="font-size:10px;color:var(--i400);">${row.note}</span></div>
        <div style="display:flex;flex-direction:column;gap:4px;align-items:flex-end;">
          <input class="est-row-input" type="number" value="${row.val}" step="1000" onchange="updateEstRowWithPeriod('${cat}',${i},this.value,'${period}')" style="width:90px;"/>
          <div class="est-period-toggle">
            <button class="est-period-btn ${period==='monthly'?'active':''}" onclick="setEstPeriod('${cat}',${i},'monthly',this)">Mo</button>
            <button class="est-period-btn ${period==='annual'?'active':''}" onclick="setEstPeriod('${cat}',${i},'annual',this)">Yr</button>
          </div>
        </div>
        <button class="est-del" onclick="delEstRow('${cat}',${i})">✕</button>
      </div>`;
    });
    html += `<button class="est-add-row" onclick="addEstRow('${cat}')">+ Add row</button></div>`;
  }

  document.getElementById('est-content').innerHTML = html;
  updateEstTotal();
}

function updateEstRow(cat, idx, val) {
  if (estRows[cat]) estRows[cat][idx].val = parseFloat(val) || 0;
