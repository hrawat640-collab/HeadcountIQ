@media print{.board-toolbar,.board-print-hide,.bkpi-del,.add-kpi-btn,.edit-hint{display:none!important}.board-wrap{padding:40px}body{background:white}[contenteditable]:hover,[contenteditable]:focus{background:transparent!important;box-shadow:none!important}}

/* FAQ PANEL */
