function buildUserPlanFromRoles() {
  if (!userPlanRoles.length) return null;
  const deptHires = {}, deptSal = {}, deptLevels = {};
  userPlanRoles.forEach(r => {
    if (!r.count || r.count < 1) return;
    const dept = r.department || 'Other';
    const lvl = r.level || 'Mid';
    const sal = (r.salary || (BM.sal[dept]||BM.sal.Operations).median * 100000);
    deptHires[dept] = (deptHires[dept]||0) + r.count;
    if (!deptSal[dept]) deptSal[dept] = sal;
    else deptSal[dept] = (deptSal[dept] + sal) / 2;
    if (!deptLevels[dept]) deptLevels[dept] = {};
    deptLevels[dept][lvl] = (deptLevels[dept][lvl]||0) + r.count;
  });
  const finalHires = Object.values(deptHires).reduce((a,b)=>a+b,0);
  const rates = getRates();
  const payroll = Object.entries(deptHires).reduce((s,[d,h])=>s+h*deptSal[d]/12,0);
  const hiringCost = payroll * rates.hiring;
  const onbCost = Object.entries(deptHires).reduce((s,[d,h])=>s+h*(deptSal[d]/12)*rates.onboard/12,0);
  const benCost = payroll * rates.benefits;
  const opsTotal = S.ops.tools+S.ops.rent+S.ops.ctors+S.ops.other;
  const totalCost = payroll+hiringCost+onbCost+benCost+opsTotal;
  const h = S.horizon;
  const phases=[{months:Math.max(1,Math.round(h*0.3)),pct:0.30},{months:Math.max(1,Math.round(h*0.4)),pct:0.50},{months:Math.max(1,h-Math.round(h*0.3)-Math.round(h*0.4)),pct:0.20}];
  const mp = buildMP(deptHires, phases, h, deptSal, {});
  return { finalHires, growthHires:finalHires, attritionHires:0, rpe:S.currRev/S.empCount,
    revGap:Math.max(0,S.tgtRev-S.currRev*1.25), maxRev:S.currRev*1.25,
    deptHires, deptSal, deptLevels, payroll, hiringCost, onbCost, benCost, opsTotal, totalCost,
    phases, mp, rates, subMap:{} };
}

