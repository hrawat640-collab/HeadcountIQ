async function recalculate(){const g=id=>document.getElementById(id);S.currRev=parseFloat(g('e-curr-rev').value)||S.currRev;S.tgtRev=parseFloat(g('e-tgt-rev').value)||S.tgtRev;S.attrition=parseFloat(g('e-attrition').value)||0;S.ops={tools:parseFloat(g('e-ops-tools').value)||0,rent:parseFloat(g('e-ops-rent').value)||0,ctors:parseFloat(g('e-ops-ctors').value)||0,other:parseFloat(g('e-ops-other').value)||0};S.rates={hiring:(parseFloat(g('e-rate-hiring').value)||18)/100,onboard:parseFloat(g('e-rate-onboard').value)||1.25,benefits:(parseFloat(g('e-rate-benefits').value)||13)/100};g('curr-rev').value=S.currRev;g('tgt-rev').value=S.tgtRev;g('attrition-rate').value=S.attrition;closeEditDrawer();destroyCharts();const bal=computePlan(1.0),cons=computePlan(0.6),agg=computePlan(1.4);plan={bal,cons,agg};const health=computeHealth(bal),insights=buildInsights(bal,health),conf=computeConf();populateResults(bal,cons,agg,health,insights,conf);setTimeout(()=>buildAllCharts(),60);showToast('Plan recalculated');}

function setCurr(code,btn){document.querySelectorAll('.ctbtn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');CURR=code==='INR'?{code:'INR',sym:'₹',fx:1}:{code:'USD',sym:'$',fx:0.012};['p1','p2','p3','p4','p5','p6','ep1','ep2','ep3','ep4','ep5','ep6','fp1','fp2'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=CURR.sym;});const cs=document.getElementById('col-sym');if(cs)cs.textContent=CURR.sym;calcOps();if(isDemoMode)setTimeout(()=>launchDemo(),100);}
function selBizChip(el){document.querySelectorAll('.biz-chip').forEach(c=>c.classList.remove('sel'));el.classList.add('sel');bizModel=el.dataset.val;}
function setStar(v){fbRating=v;document.querySelectorAll('.star-btn').forEach(b=>b.classList.toggle('active',parseInt(b.dataset.v)<=v));}
function setSalView(v){salView=v;if(plan)renderLevelTable(activePlanState==='user'&&userPlanRoles.length?buildUserPlanFromRoles():plan.bal);}
function setMView(v,btn){mView=v;document.querySelectorAll('.vbtn').forEach(b=>b.classList.remove('active'));if(btn)btn.classList.add('active');if(plan)renderMPlan((activePlanState==='user'&&userPlanRoles.length?buildUserPlanFromRoles():plan.bal).mp,v);}
function openPaywall(){document.getElementById('paywall-modal').classList.add('open');}
function closePaywall(){document.getElementById('paywall-modal').classList.remove('open');}
function openPayModal(){document.getElementById('pay-modal').classList.add('open');}
function closePayModal(){document.getElementById('pay-modal').classList.remove('open');}
function copyUpi(){navigator.clipboard.writeText('hrawat640@okaxis').then(()=>{const b=document.querySelector('.copy-btn');b.textContent='Copied!';setTimeout(()=>b.textContent='Copy',2000);});}
function toggleBank(){const el=document.getElementById('bank-wrap');el.style.display=el.style.display==='none'?'block':'none';}
function setBilling(period){billingPeriod=period;const isAnn=period==='annual';document.getElementById('bill-mo')?.classList.toggle('active',!isAnn);document.getElementById('bill-yr')?.classList.toggle('active',isAnn);const pp=document.getElementById('pro-price');if(pp)pp.innerHTML=isAnn?'₹12,999<small>/yr</small>':'₹1,499<small>/mo</small>';const pn=document.getElementById('pro-note');if(pn)pn.textContent=isAnn?'~$156/yr · 2 months free':'~$18/mo · cancel anytime';const pb=document.getElementById('pro-pay-btn');if(pb)pb.textContent=isAnn?'Pay ₹12,999/year via UPI':'Pay ₹1,499 via UPI';}
function toggleFaq(){document.getElementById('faq-panel').classList.toggle('open');}
function swFaqTab(tab){['faq','ask','req'].forEach(t=>{const b=document.getElementById('ftab-'+t),el=document.getElementById(t+'-body');if(b)b.classList.toggle('active',t===tab);if(el)el.style.display=t===tab?'':'none';});}
function buildFaq(){document.getElementById('faq-body').innerHTML=FAQS.map((f,i)=>'<div class="faq-item"><button class="faq-q" id="faq-q-'+i+'" onclick="toggleFaqItem('+i+')">'+f.q+'<span class="faq-q-arrow">▾</span></button><div class="faq-a" id="faq-a-'+i+'">'+f.a+'</div></div>').join('');}
function toggleFaqItem(i){document.getElementById('faq-q-'+i)?.classList.toggle('open');document.getElementById('faq-a-'+i)?.classList.toggle('open');}
function useAttritionBenchmark(){const BENCH={SaaS:18,Gaming:28,FinTech:20,'E-commerce':25,Healthcare:15,EdTech:22,Services:20,Marketplace:22};const rate=BENCH[S.industry]||18;document.getElementById('attrition-rate').value=rate;updateAttritionPreview();showToast('Using '+rate+'% — benchmark for '+S.industry);}
function showToast(msg,d=3000){let el=document.getElementById('hiq-toast');if(!el){el=document.createElement('div');el.id='hiq-toast';el.style.cssText='position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:var(--i900);color:white;padding:10px 20px;border-radius:30px;font-size:13px;font-weight:500;z-index:9999;box-shadow:var(--e2);transition:opacity .3s;pointer-events:none;font-family:var(--ss);white-space:nowrap;';document.body.appendChild(el);}el.textContent=msg;el.style.opacity='1';clearTimeout(el._t);el._t=setTimeout(()=>el.style.opacity='0',d);}
function updateFundSignal(){currentFunds=parseFloat(document.getElementById('current-funds')?.value)||0;monthlyBurnRate=parseFloat(document.getElementById('monthly-burn')?.value)||0;const sig=document.getElementById('fund-signal');if(!sig||!currentFunds){if(sig)sig.innerHTML='';return;}const burn=monthlyBurnRate||currentFunds*0.05;const rwy=burn>0?Math.round(currentFunds/burn):99;const cls=rwy>18?'ok':rwy>9?'warn':'danger';const msg=rwy>18?'<strong>Good position:</strong> Approximately '+rwy+' months runway at current burn.':rwy>9?'<strong>Monitor:</strong> Approximately '+rwy+' months runway. Plan your fundraise timeline.':'<strong>Fundraise signal:</strong> Approximately '+rwy+' months runway. Begin fundraising now.';sig.innerHTML='<div class="finance-fund-alert '+cls+'">'+msg+'</div>';}
function selectStartMonth(el,idx){document.querySelectorAll('.month-chip').forEach(c=>c.classList.remove('sel'));el.classList.add('sel');planStartMonth=idx;}
function populateHealthDeptFilter(bal){const sel=document.getElementById('health-dept-filter');if(!sel)return;const depts=Object.keys(BM.ratio[S.industry]||BM.ratio.Default);sel.innerHTML='<option value="all">All departments</option>'+depts.map(d=>'<option>'+d+'</option>').join('');sel.onchange=()=>filterHealthByDept();}
function filterHealthByDept(){const sel=document.getElementById('health-dept-filter');if(!sel)return;const f=sel.value;document.querySelectorAll('.heuristic-table tbody tr').forEach(row=>{const td=row.querySelector('td:first-child');row.style.display=(f==='all'||!td||td.textContent.trim()===f)?'':'none';});}
